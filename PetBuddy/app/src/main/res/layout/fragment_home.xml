<?xml version="1.0" encoding="utf-8"?>

<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- DATE -->
        <TextView
            android:id="@+id/homeDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="13/03/2026"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <!-- TODO TITLE -->
        <TextView
            android:id="@+id/textTodoToday"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Todo today"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <!-- TODO LIST -->
        <FrameLayout
            android:id="@+id/todoContainer"
            android:layout_width="0dp"
            android:layout_height="110dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/textTodoToday"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>

            <TextView
                android:id="@+id/tvNoTodo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="No tasks today"
                android:gravity="center"
                android:textColor="#888888"
                android:visibility="gone"/>

        </FrameLayout>

        <!-- FEEDING HEADER -->
        <LinearLayout
            android:id="@+id/feedingRow"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@id/todoContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Feeding Today"
                android:textSize="17sp"
                android:textStyle="bold"/>

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/baseline_arrow_forward_ios_24"
                app:tint="#888888"/>

        </LinearLayout>

        <!-- FEEDING LIST -->
        <FrameLayout
            android:id="@+id/feedingContainer"
            android:layout_width="0dp"
            android:layout_height="220dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/feedingRow"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView3"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>

            <TextView
                android:id="@+id/tvNoFeeding"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="No feeding today"
                android:gravity="center"
                android:textColor="#888888"
                android:visibility="gone"/>

        </FrameLayout>

        <!-- UPCOMING HEADER -->
        <LinearLayout
            android:id="@+id/upcomingRow"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@id/feedingContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Upcoming Activities"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/baseline_arrow_forward_ios_24"
                app:tint="#888888"/>

        </LinearLayout>

        <!-- UPCOMING LIST -->
        <FrameLayout
            android:id="@+id/upcomingContainer"
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/upcomingRow"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView2"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>

            <TextView
                android:id="@+id/tvNoUpcoming"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="No upcoming activities"
                android:gravity="center"
                android:textColor="#888888"
                android:visibility="gone"/>

        </FrameLayout>

        <!-- EXPENSE CARD -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardExpense"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/element_color"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/upcomingContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:text="Expense"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/tvExpenseMonth"
                        android:text="This month"
                        android:textColor="#777777"
                        android:textSize="14sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                </LinearLayout>

                <TextView
                    android:id="@+id/tvExpenseAmount"
                    android:text="฿0"
                    android:textColor="@color/brown"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginStart="8dp"
                    android:src="@drawable/baseline_arrow_forward_ios_24"
                    app:tint="#888888"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
