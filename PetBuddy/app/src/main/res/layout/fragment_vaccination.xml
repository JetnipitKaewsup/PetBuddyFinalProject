<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    tools:context=".fragment.VaccinationFragment">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/brown"
        app:layout_constraintTop_toTopOf="parent"
        app:title="ประวัติวัคซีน"
        app:titleTextColor="@android:color/white"
        app:navigationIcon="@drawable/ic_arrow_back"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Pet Name and Change Button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvPetName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="ชื่อสัตว์เลี้ยง"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/brown"/>

                <Button
                    android:id="@+id/btnChangePet"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="เปลี่ยน"
                    android:backgroundTint="@color/brown"/>
            </LinearLayout>

            <!-- Progress Bar -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:layout_marginTop="20dp"
                android:visibility="gone"/>

            <!-- Next Vaccine Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/layoutNextVaccine"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="วัคซีนเข็มถัดไป"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/brown"/>

                        <ImageButton
                            android:id="@+id/btnEditNext"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_edit"
                            android:background="?selectableItemBackgroundBorderless"
                            android:tint="@color/brown"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvNextVaccineName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="ชื่อวัคซีน"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvNextDose"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="เข็มที่"
                        android:textSize="14sp"/>

                    <TextView
                        android:id="@+id/tvNextDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="วันที่"
                        android:textSize="14sp"/>

                    <TextView
                        android:id="@+id/tvNextDaysLeft"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="อีก X วัน"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/brown"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Latest Vaccine -->
            <LinearLayout
                android:id="@+id/layoutLatestVaccine"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="วัคซีนล่าสุด"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvLatestVaccineName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="- ชื่อวัคซีน"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/tvLatestDose"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  เข็มที่"
                    android:textSize="14sp"
                    android:layout_marginStart="8dp"/>

                <TextView
                    android:id="@+id/tvLatestDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  วันที่"
                    android:textSize="14sp"
                    android:layout_marginStart="8dp"/>

                <TextView
                    android:id="@+id/tvLatestTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  เวลา"
                    android:textSize="14sp"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

            <!-- Core Vaccines -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="วัคซีนหลัก"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvCoreVaccines"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="DHPP / DHPPL\nRabies\nOther"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"/>

            <!-- Recent Vaccines Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="ประวัติล่าสุด"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <Button
                    android:id="@+id/btnViewAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ดูทั้งหมด"
                    android:backgroundTint="@color/brown"/>
            </LinearLayout>

            <!-- Recent Vaccines RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRecentVaccines"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false"/>

            <!-- All Records RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAllRecords"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false"
                android:visibility="gone"/>

            <!-- No Data Message -->
            <TextView
                android:id="@+id/tvNoData"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="ยังไม่มีประวัติการฉีดวัคซีน\nกดปุ่ม + เพื่อเพิ่มข้อมูล"
                android:textSize="16sp"
                android:textColor="@color/brown"
                android:gravity="center"
                android:visibility="gone"/>

        </LinearLayout>

    </ScrollView>

    <!-- Floating Action Button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddVaccine"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:src="@drawable/ic_add"
        android:contentDescription="เพิ่มวัคซีน"
        app:backgroundTint="@color/brown"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>