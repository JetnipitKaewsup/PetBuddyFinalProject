<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFDF6"
    tools:context=".activity.RegisterActivity">

    <EditText
        android:id="@+id/editUsername"
        android:layout_width="333dp"
        android:layout_height="59dp"
        android:layout_marginTop="260dp"
        android:background="@drawable/background_input_field"
        android:hint="Username"
        android:inputType="text"
        android:padding="14dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/editTextTextEmailAddress"
        android:layout_width="333dp"
        android:layout_height="59dp"
        android:background="@drawable/background_input_field"
        android:hint="Email"
        android:padding="14dp"
        android:inputType="textEmailAddress"
        app:layout_constraintTop_toBottomOf="@id/editUsername"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="15dp"/>

    <EditText
        android:id="@+id/editTextTextPassword"
        android:layout_width="333dp"
        android:layout_height="59dp"
        android:background="@drawable/background_input_field"
        android:hint="Password"
        android:padding="14dp"
        android:inputType="textPassword"
        app:layout_constraintTop_toBottomOf="@id/editTextTextEmailAddress"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="15dp"/>

    <EditText
        android:id="@+id/editConfPass"
        android:layout_width="333dp"
        android:layout_height="59dp"
        android:background="@drawable/background_input_field"
        android:hint="Confirm Password"
        android:padding="14dp"
        android:inputType="textPassword"
        app:layout_constraintTop_toBottomOf="@id/editTextTextPassword"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="15dp"/>

    <Button
        android:id="@+id/buttonReg"
        android:layout_width="244dp"
        android:layout_height="55dp"
        android:text="Register"
        android:textSize="18sp"
        android:backgroundTint="#A8817A"
        app:layout_constraintTop_toBottomOf="@id/editConfPass"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="25dp"/>

    <ImageView
        android:id="@+id/uploadPic"
        android:layout_width="194dp"
        android:layout_height="194dp"
        app:layout_constraintBottom_toTopOf="@+id/editUsername"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/baseline_person_24"
        android:background="@drawable/brown_oval_bg"/>

</androidx.constraintlayout.widget.ConstraintLayout>