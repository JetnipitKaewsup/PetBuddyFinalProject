<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    android:foreground="?attr/selectableItemBackground"
    android:backgroundTint="@color/element_color"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="#15A8817A">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <!-- Pet Image -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/imagePet"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/logo_1"
            android:scaleType="centerCrop"
            app:civ_border_width="1dp"
            app:civ_border_color="#15A8817A"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <!-- Pet Name -->
        <TextView
            android:id="@+id/namePet"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Buddy"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/brown"
            app:layout_constraintStart_toEndOf="@id/imagePet"
            app:layout_constraintTop_toTopOf="@id/imagePet"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Breed -->
        <TextView
            android:id="@+id/breedPet"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Golden Retriever"
            android:textSize="14sp"
            android:textColor="#7A5C57"
            android:layout_marginTop="4dp"
            app:layout_constraintStart_toStartOf="@id/namePet"
            app:layout_constraintTop_toBottomOf="@id/namePet"
            app:layout_constraintEnd_toEndOf="@id/namePet"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>