<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor"
    tools:context=".fragment.FeedingAlarmFragment">
    <!-- Toolbar -->

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        app:title="Feeding - Feed Alarm"
        app:titleTextColor="@color/brown"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">



            <!-- Clock -->

            <ImageView
                android:id="@+id/imgClock"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:contentDescription="Clock icon"
                android:src="@drawable/ic_clock"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Time Row -->

            <LinearLayout
                android:id="@+id/timeRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="36dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/imgClock"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Time"
                    android:textSize="16sp"
                    android:textStyle="bold"/>




                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=":"
                    android:textSize="22sp"
                    android:layout_marginStart="6dp"/>

                <!-- Minute -->

                <TextView
                    android:id="@+id/tvTime"
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:gravity="center"
                    android:text="08:30 AM"
                    android:textSize="18sp"
                    android:background="@drawable/background_input_field"
                    android:clickable="true"
                    android:focusable="true"/>

                <!-- AM PM -->

            </LinearLayout>

            <!-- Repeat -->

            <LinearLayout
                android:id="@+id/repeatGroup"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/timeRow"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOnce"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Once"
                    android:background="@drawable/bg_frequency_button"
                    app:backgroundTint="@null"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEveryday"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Everyday"
                    android:background="@drawable/bg_frequency_button"
                    app:backgroundTint="@null"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCustom"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Custom"
                    android:background="@drawable/bg_frequency_button"
                    app:backgroundTint="@null"/>

            </LinearLayout>

            <!-- Day Chips -->

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipDays"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:layout_marginTop="12dp"
                app:singleSelection="false"
                app:layout_constraintTop_toBottomOf="@id/repeatGroup"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipMon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:text="Mon"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipTue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:text="Tue"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipWed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:text="Wed"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipThu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:text="Thu"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipFri"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:text="Fri"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:text="Sat"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSun"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:text="Sun"/>

            </com.google.android.material.chip.ChipGroup>

            <!-- Title -->

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Title"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@id/chipDays"
                app:layout_constraintStart_toStartOf="parent"/>

            <EditText
                android:id="@+id/etTitle"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:hint="Food name"
                android:background="@drawable/background_input_field"
                android:padding="12dp"
                app:layout_constraintTop_toBottomOf="@id/tvTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- Type -->

            <TextView
                android:id="@+id/tvType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Type"
                android:layout_marginTop="14dp"
                app:layout_constraintTop_toBottomOf="@id/etTitle"
                app:layout_constraintStart_toStartOf="parent"/>

            <Spinner
                android:id="@+id/spinnerType"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:background="@drawable/background_input_field"
                app:layout_constraintTop_toBottomOf="@id/tvType"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- Pet -->

            <LinearLayout
                android:id="@+id/petSection"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:background="@drawable/background_input_field"
                android:padding="12dp"
                app:layout_constraintTop_toBottomOf="@id/spinnerType"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvPet"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Pets"
                        android:textStyle="bold"
                        android:textSize="16sp"/>

                    <TextView
                        android:id="@+id/btnEditPet"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="edit"
                        android:textColor="@color/brown"/>

                </LinearLayout>


                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/petRow"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="10dp"
                    android:contentDescription="Show pet"
                    tools:listitem="@layout/item_pet_icon"/>

            </LinearLayout>
            <!-- Note -->

            <TextView
                android:id="@+id/tvNote"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Note"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/petSection"
                app:layout_constraintStart_toStartOf="parent"/>

            <EditText
                android:id="@+id/etNote"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:background="@drawable/background_input_field"
                android:padding="12dp"
                android:hint="additional note"
                app:layout_constraintTop_toBottomOf="@id/tvNote"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- Save -->

            <Button
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginTop="40dp"
                android:backgroundTint="@color/brown"
                android:text="Save changes"
                app:layout_constraintTop_toBottomOf="@id/etNote"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>