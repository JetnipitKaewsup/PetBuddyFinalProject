<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <!-- Header -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create Pet Profile"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/brown"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add information about your pet"
                android:textSize="14sp"
                android:textColor="#7A6A5C"
                android:layout_marginTop="4dp"/>

            <!-- Pet Image -->

            <FrameLayout
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_marginTop="24dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/imageProfilePet"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/baseline_pets_24"
                    android:background="@drawable/brown_oval_bg"
                    app:shapeAppearanceOverlay="@style/CircleImage"/>

            </FrameLayout>

            <!-- Form Card -->

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:padding="20dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:strokeColor="@android:color/transparent"
                app:cardBackgroundColor="@color/backgroundColor">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Pet Name -->

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/petNameLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxBackgroundMode="filled"
                        app:boxBackgroundColor="@color/light_brown"
                        app:boxStrokeWidth="0dp"
                        app:boxStrokeWidthFocused="0dp"
                        app:boxCornerRadiusTopStart="20dp"
                        app:boxCornerRadiusTopEnd="20dp"
                        app:boxCornerRadiusBottomStart="20dp"
                        app:boxCornerRadiusBottomEnd="20dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/crePUser"
                            android:layout_width="match_parent"
                            android:layout_height="55dp"
                            android:hint="Pet Name"
                            android:background="@null"
                            android:paddingHorizontal="16dp"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Pet Type -->

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/petTypeLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:endIconMode="dropdown_menu"
                        app:boxBackgroundMode="filled"
                        app:boxBackgroundColor="@color/light_brown"
                        app:boxStrokeWidth="0dp"
                        app:boxStrokeWidthFocused="0dp"
                        app:boxCornerRadiusTopStart="20dp"
                        app:boxCornerRadiusTopEnd="20dp"
                        app:boxCornerRadiusBottomStart="20dp"
                        app:boxCornerRadiusBottomEnd="20dp">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/petDropdown"
                            android:layout_width="match_parent"
                            android:layout_height="55dp"
                            android:hint="Pet Type"
                            android:inputType="none"
                            android:background="@null"
                            android:paddingHorizontal="16dp"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Breed -->

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/breedLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:endIconMode="dropdown_menu"
                        app:boxBackgroundMode="filled"
                        app:boxBackgroundColor="@color/light_brown"
                        app:boxStrokeWidth="0dp"
                        app:boxStrokeWidthFocused="0dp"
                        app:boxCornerRadiusTopStart="20dp"
                        app:boxCornerRadiusTopEnd="20dp"
                        app:boxCornerRadiusBottomStart="20dp"
                        app:boxCornerRadiusBottomEnd="20dp">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/breedDropdown"
                            android:layout_width="match_parent"
                            android:layout_height="55dp"
                            android:hint="Breed"
                            android:inputType="text"
                            android:background="@null"
                            android:paddingHorizontal="16dp"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Gender -->

                    <RadioGroup
                        android:id="@+id/radioGroupSex"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <RadioButton
                            android:id="@+id/radioFemale"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Female"/>

                        <RadioButton
                            android:id="@+id/radioMale"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Male"
                            android:layout_marginStart="24dp"/>

                    </RadioGroup>

                    <!-- Birthdate -->

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/birthLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:boxBackgroundMode="filled"
                        app:boxBackgroundColor="@color/light_brown"
                        app:boxStrokeWidth="0dp"
                        app:boxStrokeWidthFocused="0dp"
                        app:boxCornerRadiusTopStart="20dp"
                        app:boxCornerRadiusTopEnd="20dp"
                        app:boxCornerRadiusBottomStart="20dp"
                        app:boxCornerRadiusBottomEnd="20dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/petDate"
                            android:layout_width="match_parent"
                            android:layout_height="55dp"
                            android:hint="Birthdate"
                            android:focusable="false"
                            android:clickable="true"
                            android:background="@null"
                            android:paddingHorizontal="16dp"/>

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Create Button -->

            <com.google.android.material.button.MaterialButton
                android:id="@+id/crePetBtn"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Create Pet Profile"
                android:textSize="16sp"
                android:textColor="@android:color/white"
                android:layout_marginTop="24dp"
                android:backgroundTint="@color/brown"
                app:cornerRadius="28dp"/>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>